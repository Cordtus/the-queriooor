{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "",
	"outputDirectory": ".",
	"framework": null,
	"cleanUrls": true,
	"functions": {
		"api/proxy.js": {
			"maxDuration": 30
		}
	},
	"headers": [
		{
			"source": "/api/(.*)",
			"headers": [
				{ "key": "Access-Control-Allow-Origin", "value": "*" },
				{ "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
			]
		}
	]
}
